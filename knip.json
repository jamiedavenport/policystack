{
	"$schema": "https://unpkg.com/knip@5/schema.json",
	"tags": ["-lintignore"],
	"ignoreBinaries": ["tsc"],
	"workspaces": {
		".": {},
		"apps/docs": {
			"entry": ["source.config.ts"]
		},
		"packages/*": {
			"entry": ["rolldown.config.ts"],
			"ignoreDependencies": ["@openpolicy/tooling"]
		},
		"packages/renderers": {
			"ignoreDependencies": ["@openpolicy/tooling"]
		},
		"examples/tanstack": {
			"entry": ["src/openpolicy.ts"]
		}
	}
}
