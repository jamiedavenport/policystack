{
	"name": "@policystack/svelte",
	"version": "0.0.34",
	"description": "Svelte components for PolicyStack",
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/jamiedavenport/policystack",
		"directory": "packages/svelte"
	},
	"files": [
		"dist",
		"README.md",
		"NOTICE.md"
	],
	"type": "module",
	"sideEffects": false,
	"exports": {
		"./policy": {
			"types": "./dist/policy.d.ts",
			"svelte": "./dist/policy.js",
			"default": "./dist/policy.js"
		},
		"./consent": {
			"types": "./dist/consent/index.d.ts",
			"svelte": "./dist/consent/index.js",
			"default": "./dist/consent/index.js"
		},
		"./consent/stores": {
			"types": "./dist/consent/stores.d.ts",
			"svelte": "./dist/consent/stores.js",
			"default": "./dist/consent/stores.js"
		},
		"./package.json": "./package.json"
	},
	"publishConfig": {
		"exports": {
			"./policy": {
				"types": "./dist/policy.d.ts",
				"svelte": "./dist/policy.js",
				"default": "./dist/policy.js"
			},
			"./consent": {
				"types": "./dist/consent/index.d.ts",
				"svelte": "./dist/consent/index.js",
				"default": "./dist/consent/index.js"
			},
			"./consent/stores": {
				"types": "./dist/consent/stores.d.ts",
				"svelte": "./dist/consent/stores.js",
				"default": "./dist/consent/stores.js"
			},
			"./package.json": "./package.json"
		}
	},
	"scripts": {
		"dev": "svelte-package -i ./src/lib -o ./dist --watch",
		"build": "svelte-package -i ./src/lib -o ./dist",
		"check-types": "svelte-check --tsconfig ./tsconfig.json",
		"test": "vp test"
	},
	"devDependencies": {
		"@policystack/core": "workspace:*",
		"@policystack/tooling": "workspace:*",
		"@sveltejs/package": "^2.4.4",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@testing-library/svelte": "^5.3.1",
		"happy-dom": "^15.11.7",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"vite-plus": "catalog:"
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	}
}
