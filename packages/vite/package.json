{
	"name": "@openpolicy/vite",
	"version": "0.0.32",
	"description": "Vite plugin that scans source files for @openpolicy/sdk collecting()/thirdParty() calls and populates the auto-collected registry at build time",
	"keywords": [
		"openpolicy",
		"privacy-policy",
		"vite-plugin"
	],
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/jamiedavenport/openpolicy",
		"directory": "packages/vite"
	},
	"files": [
		"dist",
		"README.md",
		"NOTICE.md"
	],
	"type": "module",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"scripts": {
		"dev": "vp pack --watch",
		"build": "vp pack",
		"check-types": "tsc --noEmit",
		"test": "vp test"
	},
	"dependencies": {
		"@openpolicy/core": "workspace:*",
		"bundle-require": "^5.1.0",
		"oxc-parser": "^0.124.0"
	},
	"devDependencies": {
		"@openpolicy/sdk": "workspace:*",
		"@openpolicy/tooling": "workspace:*",
		"esbuild": "^0.25.12",
		"vite": "catalog:",
		"vite-plus": "catalog:"
	},
	"peerDependencies": {
		"vite": ">=4.0.0"
	}
}
