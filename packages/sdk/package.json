{
	"name": "@policystack/sdk",
	"version": "0.0.34",
	"description": "Public API for defining privacy policies with PolicyStack",
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/jamiedavenport/policystack",
		"directory": "packages/sdk"
	},
	"files": [
		"dist",
		"llms.txt",
		"README.md",
		"NOTICE.md"
	],
	"type": "module",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		},
		"./consent": {
			"import": "./dist/consent.js",
			"types": "./dist/consent.d.ts"
		},
		"./llms.txt": "./llms.txt"
	},
	"scripts": {
		"dev": "vp pack --watch",
		"build": "vp pack && vp run gen:llms && vp run gen:skills",
		"gen:llms": "node scripts/gen-llms.mjs",
		"gen:skills": "node scripts/gen-skills.mjs",
		"check-types": "tsc --noEmit",
		"test": "vp test"
	},
	"dependencies": {},
	"devDependencies": {
		"@policystack/core": "workspace:*",
		"@policystack/tooling": "workspace:*",
		"vite-plus": "catalog:"
	}
}
