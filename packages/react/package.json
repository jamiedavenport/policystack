{
	"name": "@openpolicy/react",
	"version": "0.0.34",
	"description": "React components and hooks for OpenPolicy",
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/jamiedavenport/openpolicy",
		"directory": "packages/react"
	},
	"files": [
		"dist",
		"README.md",
		"NOTICE.md"
	],
	"type": "module",
	"sideEffects": false,
	"exports": {
		"./policy": {
			"import": "./dist/policy.js",
			"types": "./dist/policy.d.ts"
		},
		"./consent": {
			"import": "./dist/consent.js",
			"types": "./dist/consent.d.ts"
		},
		"./provider": {
			"import": "./dist/provider.js",
			"types": "./dist/provider.d.ts"
		},
		"./package.json": "./package.json"
	},
	"publishConfig": {
		"exports": {
			"./policy": {
				"import": "./dist/policy.js",
				"types": "./dist/policy.d.ts"
			},
			"./consent": {
				"import": "./dist/consent.js",
				"types": "./dist/consent.d.ts"
			},
			"./provider": {
				"import": "./dist/provider.js",
				"types": "./dist/provider.d.ts"
			},
			"./package.json": "./package.json"
		}
	},
	"scripts": {
		"dev": "vp pack --watch",
		"build": "vp pack",
		"check-types": "tsc --noEmit",
		"test": "vp test"
	},
	"devDependencies": {
		"@openpolicy/core": "workspace:*",
		"@openpolicy/sdk": "workspace:*",
		"@openpolicy/tooling": "workspace:*",
		"@testing-library/react": "^16.3.2",
		"@types/react": "^18.0.0 || ^19.0.0",
		"@types/react-dom": "^18.0.0 || ^19.0.0",
		"happy-dom": "^15.11.7",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"vite-plus": "catalog:"
	},
	"peerDependencies": {
		"react": ">=18",
		"react-dom": ">=18"
	}
}
