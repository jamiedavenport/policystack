{
	"name": "@policystack/vue",
	"version": "1.0.0",
	"description": "Vue components for PolicyStack",
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/jamiedavenport/policystack",
		"directory": "packages/vue"
	},
	"files": [
		"dist",
		"README.md",
		"NOTICE.md"
	],
	"type": "module",
	"sideEffects": false,
	"exports": {
		"./policy": {
			"import": "./dist/policy.js",
			"types": "./dist/policy.d.ts"
		},
		"./consent": {
			"import": "./dist/consent.js",
			"types": "./dist/consent.d.ts"
		},
		"./provider": {
			"import": "./dist/provider.js",
			"types": "./dist/provider.d.ts"
		},
		"./package.json": "./package.json"
	},
	"publishConfig": {
		"exports": {
			"./policy": {
				"import": "./dist/policy.js",
				"types": "./dist/policy.d.ts"
			},
			"./consent": {
				"import": "./dist/consent.js",
				"types": "./dist/consent.d.ts"
			},
			"./package.json": "./package.json"
		}
	},
	"scripts": {
		"dev": "vp pack --watch",
		"build": "vp pack",
		"check-types": "tsc --noEmit",
		"test": "vp test"
	},
	"devDependencies": {
		"@policystack/core": "workspace:*",
		"@policystack/tooling": "workspace:*",
		"@vue/test-utils": "^2.4.10",
		"happy-dom": "^15.11.7",
		"vite-plus": "catalog:",
		"vue": "^3.5.0"
	},
	"peerDependencies": {
		"vue": ">=3.5"
	}
}
